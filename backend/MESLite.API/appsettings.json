{
  "Database": {
    "Provider": "SqlServer"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=MESLite;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True",
    "SqliteConnection": "Data Source=meslite.db"
  },
  "Simulator": {
    "Enabled": true,
    "IntervalSeconds": 5,
    "SpeedFactor": 1.0,
    "OeeBroadcastEveryTicks": 6
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173", "http://localhost:3000" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
